# Neon Postgres connection string (pooled), from the Neon dashboard.
DATABASE_URL=

# bcrypt hash of the admin password — generate with:
#   npm run hash-password -- "your password here"
# IMPORTANT: escape every `$` in the resulting hash as `\$` before pasting it
# here. Next.js's env loader expands unescaped `$word` as a variable
# reference (like shell), which silently corrupts bcrypt hashes — they're
# full of `$` — turning them into garbage that can never match. `npm run
# hash-password` prints the value already escaped and ready to paste.
ADMIN_PASSWORD_HASH=

# Random secret used to sign admin session JWTs. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Random secret used to HMAC-hash visitor IPs before they touch the DB. Generate with:
#   openssl rand -base64 32
IP_HASH_SECRET=

# Random secret Vercel Cron must present to hit /api/cron/cleanup. Generate with:
#   openssl rand -base64 32
CRON_SECRET=
